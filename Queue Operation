#include <iostream>
using namespace std;

#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

// Enqueue operation
void enqueue(int value) {
    if (rear == MAX - 1) {
        cout << "Queue is Full\n";
    } else {
        if (front == -1) front = 0;
        rear++;
        queue[rear] = value;
        cout << value << " inserted into queue\n";
    }
}

// Dequeue operation
void dequeue() {
    if (front == -1 || front > rear) {
        cout << "Queue is Empty\n";
    } else {
        cout << queue[front] << " deleted from queue\n";
        front++;
    }
}

// Peek operation
void peek() {
    if (front == -1 || front > rear) {
        cout << "Queue is Empty\n";
    } else {
        cout << "Front element is: " << queue[front] << endl;
    }
}

// Display queue
void display() {
    if (front == -1 || front > rear) {
        cout << "Queue is Empty\n";
    } else {
        cout << "Queue elements: ";
        for (int i = front; i <= rear; i++) {
            cout << queue[i] << " ";
        }
        cout << endl;
    }
}

// Main function
int main() {
    enqueue(10);
    enqueue(20);
    enqueue(30);
    display();

    dequeue();
    display();

    peek();

    return 0;
}
